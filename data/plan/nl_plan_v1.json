{
  "meta": {
    "version": "1.0",
    "created": "2026-06-06",
    "language": "nl",
    "target_cefr": "A2",
    "daily_goal_minutes": 20,
    "mastery_threshold": 0.80,
    "description": "A0 → A1 → A2 Dutch learning path for daily life in the Netherlands and the NT2 A2 exam"
  },

  "mastery_checks": {
    "flashcard_80pct": {
      "description": "≥ 80% of the chapter's flashcards are no longer in 'new' state (have been reviewed at least once via SRS)",
      "storage": "nl_srs_v3[chapterId]",
      "pass_when": "mastered_count / total_count >= 0.80"
    },
    "verb_quiz_80": {
      "description": "Verb lesson quiz totalCorrect / totalAnswered ≥ 80%",
      "storage": "nl_verbs_v3.lessons[lessonId]",
      "pass_when": "totalCorrect / totalAnswered >= 0.80"
    },
    "stars_2plus": {
      "description": "Getallen level best score ≥ 2 stars (≥ 70% correct in quiz)",
      "storage": "nl_num_progress[levelId]",
      "pass_when": "Math.max(listen, quiz) >= 2"
    },
    "count_done": {
      "description": "A numeric counter reaches the target value",
      "examples": "klanken sounds done, news articles read, podcast episodes listened, sentence days"
    },
    "story_quiz_80": {
      "description": "Story quiz score ≥ 80% (nl_s2_quiz_v1[storyId].completed = true)",
      "storage": "nl_s2_quiz_v1",
      "pass_when": "completed_count >= target_count"
    },
    "practiced_once": {
      "description": "The dialogue or tool has been used at least once",
      "storage": "nl_dlg_v1.stats[dialogueId].count >= 1"
    },
    "streak_days": {
      "description": "5 sentences per day for N consecutive days",
      "storage": "nl_sentence_v1.streak",
      "pass_when": "streak >= target_days"
    }
  },

