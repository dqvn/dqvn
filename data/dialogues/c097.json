{
  "dialogue_title": "Autopech Onderweg – Nederlandse Conversatie",
  "language": "Dutch",
  "video_url": "https://www.youtube.com/shorts/CSAPbUIM9LE",
  "roles": {
    "A": "Driver (Woman)",
    "B": "Roadside Assistance Worker (Man)"
